__pycache__
*.o
build
cmake/sys.cmake.ext
*.png
*.dat
*.txt
*.data

# Bccti 运行产物（数据保留在 HPC 本地，不进 git）
bccTi/relax_*/output/
bccTi/relax_*/slurm-*.out

# 例外：保留这些 output 目录下的 .dat 文件和 slurm 日志
!bccTi/high_t/output/**/*.dat
!bccTi/low_t/output/**/*.dat
!bccTi/low_t_const/output/**/*.dat
!bccTi/high_*/output/**/*.dat
!bccTi/high_*/slurm-*.out
!bccTi/low_*/slurm-*.out

# 模拟 restart 和 log 文件，不进 git
*.exadis
exadis.log

# === HPC 模拟输出:忽略 output 下所有内容,但保留两个数据文件 ===
bccTi/*/output/*
!bccTi/*/output/stress_strain_dens.dat
!bccTi/*/output/timer.dat
